@{
    ViewData["Title"] = "Chat Interno";
    var sala = ViewBag.Sala as string ?? "general";
}

<div class="js-chat-wrapper">

    <!-- Encabezado del chat -->
    <div class="js-chat-header">
        <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
             style="width:36px;height:36px;background:rgba(184,150,46,.2);border:1px solid rgba(184,150,46,.4)">
            <i class="bi bi-chat-dots-fill" style="color:var(--js-gold-light)"></i>
        </div>
        <div class="flex-grow-1">
            <div class="chat-sala">
                <span class="text-capitalize">@sala</span>
            </div>
            <div class="chat-meta">
                Sala segura · Sesión de <strong style="color:rgba(255,255,255,.88)">@User.Identity!.Name</strong>
            </div>
        </div>
        <span id="estadoConexion"
              class="badge-conexion badge bg-secondary"
              title="Estado de la conexión">
            ⏳ Conectando…
        </span>
    </div>

    <!-- Área de mensajes -->
    <div id="mensajes" class="js-chat-messages">
        <div id="cargandoHistorial"
             class="d-flex flex-column align-items-center justify-content-center h-100 text-muted gap-2"
             style="opacity:.6">
            <div class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></div>
            <small>Cargando historial de mensajes…</small>
        </div>
    </div>

    <!-- Input de mensaje -->
    <div class="js-chat-input-area">
        <div class="input-group">
            <input id="mensajeInput"
                   type="text"
                   class="form-control"
                   placeholder="Escriba un mensaje…"
                   maxlength="1000"
                   autocomplete="off"
                   aria-label="Escribir mensaje"
                   disabled />
            <button id="enviarBtn"
                    class="btn btn-primary"
                    type="button"
                    aria-label="Enviar mensaje"
                    disabled>
                <i class="bi bi-send-fill"></i>
            </button>
        </div>
        <div class="d-flex justify-content-between mt-1 px-1">
            <small class="text-muted" style="font-size:.72rem">
                <i class="bi bi-lock-fill me-1" style="color:var(--js-gold)"></i>Canal cifrado · Máx. 1 000 caracteres
            </small>
            <small id="contadorChars" class="text-muted" style="font-size:.72rem">0 / 1000</small>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

    <script>
        (function () {
            "use strict";

            const sala          = "@sala";
            const usuarioActual = "@User.Identity!.Name";

            const divMensajes = document.getElementById("mensajes");
            const input       = document.getElementById("mensajeInput");
            const btnEnviar   = document.getElementById("enviarBtn");
            const estadoBadge = document.getElementById("estadoConexion");
            const contador    = document.getElementById("contadorChars");
            const divCargando = document.getElementById("cargandoHistorial");

            let historialListo = false;

            // ── Conexión SignalR ──────────────────────────────────────────────────────
            const connection = new signalR.HubConnectionBuilder()
                .withUrl(`/chathub?sala=${encodeURIComponent(sala)}`)
                .withAutomaticReconnect([0, 2000, 5000, 10000])
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            // ── Recibir mensajes (historial + nuevos) ─────────────────────────────────
            connection.on("RecibirMensaje", (usuario, mensaje, hora) => {
                if (!historialListo) {
                    historialListo = true;
                    divCargando?.remove();
                }
                agregarMensaje(usuario, mensaje, hora);
            });

            // ── Eventos de reconexión ─────────────────────────────────────────────────
            connection.onreconnecting(() => {
                setEstado("warning", "⏳ Reconectando…");
                setInputHabilitado(false);
            });

            connection.onreconnected(() => {
                setEstado("success", "✅ Conectado");
                setInputHabilitado(true);
            });

            connection.onclose(() => {
                setEstado("danger", "❌ Sin conexión");
                setInputHabilitado(false);
            });

            // ── Iniciar conexión ──────────────────────────────────────────────────────
            connection.start()
                .then(() => {
                    setEstado("success", "✅ Conectado");
                    setInputHabilitado(true);
                    setTimeout(() => {
                        if (!historialListo) divCargando?.remove();
                    }, 1500);
                })
                .catch(err => {
                    console.error("Error al conectar al hub:", err);
                    setEstado("danger", "❌ Sin conexión");
                    if (divCargando) divCargando.innerHTML =
                        '<i class="bi bi-wifi-off fs-4 mb-1"></i><small>No se pudo cargar el historial.</small>';
                });

            // ── Enviar mensaje ────────────────────────────────────────────────────────
            function enviar() {
                const texto = input.value.trim();
                if (!texto || connection.state !== signalR.HubConnectionState.Connected) return;

                connection.invoke("EnviarMensaje", texto)
                    .catch(err => console.error("Error al enviar:", err));

                input.value = "";
                contador.textContent = "0 / 1000";
                contador.className = "text-muted";
            }

            btnEnviar.addEventListener("click", enviar);
            input.addEventListener("keypress", e => { if (e.key === "Enter") enviar(); });

            // ── Contador de caracteres ────────────────────────────────────────────────
            input.addEventListener("input", () => {
                const len = input.value.length;
                contador.textContent = `${len} / 1000`;
                contador.className = len > 900 ? "text-danger" : "text-muted";
            });

            // ── Helpers ───────────────────────────────────────────────────────────────
            function agregarMensaje(usuario, mensaje, hora) {
                const esPropio = usuario === usuarioActual;

                const wrap = document.createElement("div");
                wrap.className = `chat-bubble-wrap ${esPropio ? "own" : "other"}`;

                if (!esPropio) {
                    const avatar = document.createElement("div");
                    avatar.className = "chat-avatar";
                    avatar.textContent = usuario.charAt(0).toUpperCase();
                    wrap.appendChild(avatar);
                }

                const burbuja = document.createElement("div");
                burbuja.className = `chat-bubble ${esPropio ? "own" : "other"}`;

                if (!esPropio) {
                    const nombre = document.createElement("div");
                    nombre.className = "bubble-sender";
                    nombre.textContent = usuario;
                    burbuja.appendChild(nombre);
                }

                const textoEl = document.createElement("div");
                textoEl.textContent = mensaje;   // textContent previene XSS
                burbuja.appendChild(textoEl);

                const horaEl = document.createElement("span");
                horaEl.className = "bubble-time";
                horaEl.textContent = hora;
                burbuja.appendChild(horaEl);

                wrap.appendChild(burbuja);
                divMensajes.appendChild(wrap);
                divMensajes.scrollTop = divMensajes.scrollHeight;
            }

            function setEstado(tipo, texto) {
                estadoBadge.className = `badge-conexion badge bg-${tipo}`;
                estadoBadge.textContent = texto;
            }

            function setInputHabilitado(habilitado) {
                input.disabled    = !habilitado;
                btnEnviar.disabled = !habilitado;
                if (habilitado) input.focus();
            }

        })();
    </script>
}
