@{
    ViewData["Title"] = "Chat Interno";
}

<h1>Chat Interno</h1>

<div class="row">
    <div class="col-md-8">
        <div id="mensajes" class="border rounded p-3 mb-3 bg-light" style="height:400px; overflow-y:auto;">
        </div>
        <div class="input-group">
            <input id="mensajeInput" type="text" class="form-control" placeholder="Escribe un mensaje..." maxlength="1000" />
            <button id="enviarBtn" class="btn btn-primary" type="button">Enviar</button>
        </div>
        <small class="text-muted">Conectado como: <strong>@User.Identity!.Name</strong></small>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"
        integrity="sha512-bHoKABCqaF6hMjBZUO9NxKBijMrPpf3X5WiTJ17NpKl4pWFINBmOzQ1ZJqT1bwbdB5brfVi2tOe2lJ3QEJrQ=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .withAutomaticReconnect()
        .build();

    connection.on("RecibirMensaje", (usuario, mensaje, hora) => {
        const div = document.getElementById("mensajes");
        const item = document.createElement("div");
        item.className = "mb-2";
        item.innerHTML = `<span class="text-muted">[${hora}]</span> <strong>${escapeHtml(usuario)}:</strong> ${escapeHtml(mensaje)}`;
        div.appendChild(item);
        div.scrollTop = div.scrollHeight;
    });

    connection.start().catch(err => console.error(err));

    document.getElementById("enviarBtn").addEventListener("click", enviar);
    document.getElementById("mensajeInput").addEventListener("keypress", e => {
        if (e.key === "Enter") enviar();
    });

    function enviar() {
        const input = document.getElementById("mensajeInput");
        const texto = input.value.trim();
        if (!texto) return;
        connection.invoke("EnviarMensaje", "@User.Identity!.Name", texto)
            .catch(err => console.error(err));
        input.value = "";
    }

    function escapeHtml(str) {
        return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }
</script>
}
