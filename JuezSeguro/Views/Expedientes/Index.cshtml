@model IEnumerable<JuezSeguro.Models.Expediente>

@{
    ViewData["Title"] = "Expedientes";
}

<h1>Expedientes</h1>

@if (User.IsInRole("Juez") || User.IsInRole("Administrador"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Nuevo Expediente</a>
    </p>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>@Html.DisplayNameFor(m => m.NumeroExpediente)</th>
            <th>@Html.DisplayNameFor(m => m.Titulo)</th>
            <th>@Html.DisplayNameFor(m => m.Materia)</th>
            <th>@Html.DisplayNameFor(m => m.Estado)</th>
            <th>@Html.DisplayNameFor(m => m.FechaApertura)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NumeroExpediente</td>
                <td>@item.Titulo</td>
                <td>@item.Materia</td>
                <td>
                    <span class="badge @(item.Estado == JuezSeguro.Models.EstadoExpediente.Abierto ? "bg-success" :
                                         item.Estado == JuezSeguro.Models.EstadoExpediente.Cerrado ? "bg-secondary" : "bg-warning text-dark")">
                        @item.Estado
                    </span>
                </td>
                <td>@item.FechaApertura.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalles</a>
                    @if (User.IsInRole("Juez") || User.IsInRole("Administrador"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning ms-1">Editar</a>
                    }
                    @if (User.IsInRole("Administrador"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger ms-1">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
