@model JuezSeguro.Models.Expediente

@{
    ViewData["Title"] = "Editar Expediente";
}

<h1>Editar Expediente</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreadoPorId" />
            <input type="hidden" asp-for="FechaApertura" />

            <div class="mb-3">
                <label asp-for="NumeroExpediente" class="form-label"></label>
                <input asp-for="NumeroExpediente" class="form-control" />
                <span asp-validation-for="NumeroExpediente" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Titulo" class="form-label"></label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Materia" class="form-label"></label>
                <select asp-for="Materia" asp-items="Html.GetEnumSelectList<JuezSeguro.Models.MateriaJuridica>()" class="form-select"></select>
                <span asp-validation-for="Materia" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label"></label>
                <select asp-for="Estado" asp-items="Html.GetEnumSelectList<JuezSeguro.Models.EstadoExpediente>()" class="form-select"></select>
                <span asp-validation-for="Estado" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaCierre" class="form-label"></label>
                <input asp-for="FechaCierre" class="form-control" type="datetime-local" />
            </div>

            <div class="mb-3 form-check">
                <input asp-for="Activo" class="form-check-input" type="checkbox" />
                <label asp-for="Activo" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-warning">Guardar cambios</button>
            <a asp-action="Index" class="btn btn-secondary ms-1">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
