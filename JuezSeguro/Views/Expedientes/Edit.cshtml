@model JuezSeguro.Models.Expediente

@{
    ViewData["Title"] = "Editar Expediente";
}

<h1>Editar Expediente</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="NumeroExpediente" class="form-label"></label>
                <input asp-for="NumeroExpediente" class="form-control" />
                <span asp-validation-for="NumeroExpediente" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Titulo" class="form-label"></label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MateriaCod" class="form-label"></label>
                <select asp-for="MateriaCod" class="form-select">
                    <option value="">-- Seleccione materia --</option>
                    <option value="PENAL">Penal</option>
                    <option value="CIVIL">Civil</option>
                    <option value="LABORAL">Laboral</option>
                    <option value="ADMIN">Administrativo</option>
                    <option value="CONST">Constitucional</option>
                </select>
                <span asp-validation-for="MateriaCod" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EstadoCod" class="form-label"></label>
                <select asp-for="EstadoCod" class="form-select">
                    <option value="BORRADOR">Borrador</option>
                    <option value="REVISION">En Revisión</option>
                    <option value="PUBLICADO">Publicado</option>
                    <option value="ARCHIVADO">Archivado</option>
                </select>
                <span asp-validation-for="EstadoCod" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IdTribunal" class="form-label"></label>
                <input asp-for="IdTribunal" class="form-control" type="number" />
                <span asp-validation-for="IdTribunal" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-warning">Guardar cambios</button>
            <a asp-action="Index" class="btn btn-secondary ms-1">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
