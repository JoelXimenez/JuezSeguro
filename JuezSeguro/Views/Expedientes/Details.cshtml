@model JuezSeguro.Models.Expediente

@{
    ViewData["Title"] = "Detalle del Expediente";
}

<h1>Detalle del Expediente</h1>

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <strong>@Model.NumeroExpediente</strong> — @Model.Titulo
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.NumeroExpediente)</dt>
            <dd class="col-sm-9">@Model.NumeroExpediente</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Titulo)</dt>
            <dd class="col-sm-9">@Model.Titulo</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Descripcion)</dt>
            <dd class="col-sm-9">@Model.Descripcion</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.MateriaCod)</dt>
            <dd class="col-sm-9">@Model.MateriaCod</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.EstadoCod)</dt>
            <dd class="col-sm-9">@Model.EstadoCod</dd>

            <dt class="col-sm-3">@Html.DisplayNameFor(m => m.FechaApertura)</dt>
            <dd class="col-sm-9">@Model.FechaApertura.ToString("dd/MM/yyyy HH:mm")</dd>

            @if (!string.IsNullOrEmpty(Model.HashIntegridad))
            {
                <dt class="col-sm-3">@Html.DisplayNameFor(m => m.HashIntegridad)</dt>
                <dd class="col-sm-9"><code>@Model.HashIntegridad</code></dd>
            }
        </dl>
    </div>
</div>

<div class="mt-3">
    @if (User.IsInRole("Juez") || User.IsInRole("Administrador"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    }
    <a asp-action="Index" class="btn btn-secondary ms-1">Volver</a>
</div>
