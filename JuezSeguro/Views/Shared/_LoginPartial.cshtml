@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-center gap-1">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-2" style="color:rgba(255,255,255,.78)"
           asp-area="Identity" asp-page="/Account/Manage/Index" title="Gestionar cuenta">
            <span class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                  style="width:30px;height:30px;background:var(--js-gold);color:#fff;font-size:.75rem;font-weight:700">
                @(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "U")
            </span>
            <span class="d-none d-md-inline" style="font-size:.85rem">@User.Identity?.Name</span>
        </a>
    </li>
    <li class="nav-item">
        <form class="m-0" asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit"
                    class="btn btn-sm"
                    style="background:rgba(255,255,255,.1);color:rgba(255,255,255,.85);border:1px solid rgba(255,255,255,.2);font-size:.8rem">
                <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" style="color:rgba(255,255,255,.78)"
           asp-area="Identity" asp-page="/Account/Register">
            <i class="bi bi-person-plus me-1"></i>Registrarse
        </a>
    </li>
    <li class="nav-item">
        <a class="btn btn-sm ms-1"
           style="background:var(--js-gold);color:#fff;border:none;font-size:.85rem;font-weight:600"
           asp-area="Identity" asp-page="/Account/Login">
            <i class="bi bi-lock me-1"></i>Iniciar sesión
        </a>
    </li>
}
</ul>
