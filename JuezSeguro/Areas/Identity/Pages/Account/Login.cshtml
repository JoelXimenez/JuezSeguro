@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="login-fullbg d-flex align-items-center justify-content-center py-5"
     style="background: linear-gradient(135deg, var(--js-navy) 0%, var(--js-blue) 100%); min-height: calc(100vh - 60px);">

    <div class="w-100" style="max-width: 440px; padding: 1rem;">

        <!-- Logo / cabecera -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:64px;height:64px;background:rgba(184,150,46,.2);border:2px solid rgba(184,150,46,.4)">
                <i class="bi bi-shield-lock-fill fs-3" style="color:var(--js-gold-light)"></i>
            </div>
            <h1 class="h4 fw-bold text-white mb-1">Juez Seguro</h1>
            <p class="mb-0" style="color:rgba(255,255,255,.65);font-size:.875rem">
                Acceso al sistema judicial cifrado
            </p>
        </div>

        <!-- Tarjeta del formulario -->
        <div class="bg-white rounded-4 shadow-lg p-4">

            <h2 class="h5 fw-bold mb-1" style="color:var(--js-navy)">Iniciar sesión</h2>
            <p class="text-muted small mb-4">Ingrese sus credenciales institucionales.</p>

            <form id="account" method="post" novalidate>
                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger d-flex align-items-start gap-2 py-2 mb-3 small"
                     role="alert">
                    <i class="bi bi-exclamation-triangle-fill mt-1 flex-shrink-0"></i>
                    <div></div>
                </div>

                <!-- Correo -->
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">
                        <i class="bi bi-envelope me-1 text-muted"></i>@Html.DisplayNameFor(m => m.Input.Email)
                    </label>
                    <input asp-for="Input.Email"
                           class="form-control"
                           autocomplete="username"
                           placeholder="usuario@tribunal.gob"
                           type="email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <!-- Contraseña -->
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <label asp-for="Input.Password" class="form-label mb-0">
                            <i class="bi bi-lock me-1 text-muted"></i>@Html.DisplayNameFor(m => m.Input.Password)
                        </label>
                        <a asp-page="./ForgotPassword"
                           class="small"
                           style="color:var(--js-blue);text-decoration:none">
                            ¿Olvidó su contraseña?
                        </a>
                    </div>
                    <input asp-for="Input.Password"
                           class="form-control mt-1"
                           autocomplete="current-password"
                           placeholder="••••••••"
                           type="password" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <!-- Recordar sesión -->
                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" type="checkbox" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-muted small">
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                </div>

                <!-- Botón de acceso -->
                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar al sistema
                </button>

            </form>

        </div>

        <!-- Pie -->
        <p class="text-center mt-4 mb-0" style="color:rgba(255,255,255,.5);font-size:.78rem">
            <i class="bi bi-shield-check me-1" style="color:var(--js-gold)"></i>
            Conexión cifrada · PBKDF2 · Juez Seguro &copy; 2026
        </p>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
